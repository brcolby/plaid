# Copy this file to .env and fill in local values.
# Do not commit .env, Plaid secrets, access tokens, or Google service-account JSON.

PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=production
# Default product set used by `plaid-sheet-sync link`.
# Override per command with `--products`, for example:
#   plaid-sheet-sync link --products auth
#   plaid-sheet-sync link --products investments
#   plaid-sheet-sync link --products liabilities
PLAID_LINK_PRODUCTS=auth
# Optional Plaid transport settings. Defaults shown here bound scheduled runs and
# retry transient connection resets/timeouts before recording an Item failure.
PLAID_REQUEST_TIMEOUT_SECONDS=60
PLAID_MAX_RETRIES=2

GOOGLE_SERVICE_ACCOUNT_JSON=/absolute/path/to/google-service-account.json
GOOGLE_SHEET_ID=your-google-sheet-id

# Optional. Defaults to ~/.plaid-balance-sync/state.sqlite
PLAID_SYNC_STATE_DB=
